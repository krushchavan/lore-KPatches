      "patches_reviewed": [
        {
          "activity_type": "patch_reviewed",
          "subject": "Re: [regression] Large rsize/wsize (1MB) causes EIO after 2b092175f5e3 (\"NFS: Fix inheritance of the block sizes when automounting\")",
          "message_id": "73c3a6a03fbe30a4f4b05c7fe58b3dceda87c45b.camel@kernel.org",
          "url": "https://lore.kernel.org/all/73c3a6a03fbe30a4f4b05c7fe58b3dceda87c45b.camel@kernel.org/",
          "date": "2026-03-15T11:29:31Z",
          "in_reply_to": null,
          "ack_type": null,
          "is_ongoing": false,
          "submitted_date": null,
          "patch_version": 1,
          "version_history": [],
          "series_items": [],
          "patch_summary": "This patch addresses an issue where large read/write sizes (1MB) cause EIO errors after a specific kernel change. The problem arises from the client not adhering to the server's max_request_size, which is used to size receive buffers. To fix this, the client should clamp the length of the request to fit within the maximum allowed size, potentially dropping the last folio and forcing another request if necessary.",
          "analysis_source": "llm-per-reviewer",
          "review_comments": [
            {
              "author": "Trond Myklebust",
              "summary": "Reviewer Trond Myklebust noted that the client should clamp the length of a request to fit within max_request_size, and suggested dropping the last folio and forcing another request if necessary, but also criticized the server for not setting maxwrite to a reasonable value with enough overhead",
              "sentiment": "NEEDS_WORK",
              "sentiment_signals": [
                "requested changes"
              ],
              "has_inline_review": true,
              "tags_given": [
                "Reviewed-by"
              ],
              "raw_body": "I'm aware of what the spec says, Jeff.\n\nWe're not putting \"a bunch of operations\" before the WRITE. There's a\nSEQUENCE, PUTFH, WRITE and GETATTR.\nThe point is, we expect the value of maxwrite to be set to a reasonable\nvalue w.r.t. max_request_size so that the client doesn't have to sanity\ncheck everybody and their dog's server.\n\n-- \nTrond Myklebust\nLinux NFS client maintainer, Hammerspace\ntrondmy@kernel.org, trond.myklebust@hammerspace.com",
              "reply_to": "Jeff Layton",
              "message_date": "2026-03-15",
              "message_id": "46a87e31656d23d6246d170955ec2d633bfe63ea.camel@kernel.org",
              "analysis_source": "llm",
              "email": "trondmy@kernel.org"
            }
          ],
          "list_id": "regressions@lists.linux.dev"
        }
      ],
