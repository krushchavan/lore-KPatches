          "series_items": [
            {
              "activity_type": "patch_submitted",
              "subject": "[PATCH v5 1/2] mm: track DONTCACHE dirty pages per bdi_writeback",
              "message_id": "20260504-dontcache-v5-1-4103e58bb377@kernel.org",
              "url": "https://lore.kernel.org/all/20260504-dontcache-v5-1-4103e58bb377@kernel.org/",
              "date": "2026-05-04T13:21:28Z",
              "in_reply_to": null,
              "ack_type": null,
              "is_ongoing": false,
              "submitted_date": null,
              "patch_version": 5,
              "series_patch_count": null,
              "version_history": [],
              "series_items": [],
              "patch_summary": "This patch adds a new counter called WB_DONTCACHE_DIRTY to track the number of dirty pages that have been dirtied via RWF_DONTCACHE writes, which are used for dropbehind writes. The counter is incremented when a folio is dirtied with the dropbehind flag set and decremented when it's cleared or cleaned. This allows the writeback flusher to expedite writeback for IOCB_DONTCACHE writes without flushing the entire BDI's dirty pages, improving performance in certain scenarios.",
              "analysis_source": "llm-chunked-no-replies",
              "review_comments": [],
              "list_id": "linux-nfs@vger.kernel.org"
            },
            {
              "activity_type": "patch_submitted",
              "subject": "[PATCH v5 2/2] mm: kick writeback flusher for IOCB_DONTCACHE with targeted dirty tracking",
              "message_id": "20260504-dontcache-v5-2-4103e58bb377@kernel.org",
              "url": "https://lore.kernel.org/all/20260504-dontcache-v5-2-4103e58bb377@kernel.org/",
              "date": "2026-05-04T13:21:33Z",
              "in_reply_to": null,
              "ack_type": null,
              "is_ongoing": false,
              "submitted_date": null,
              "patch_version": 5,
              "series_patch_count": null,
              "version_history": [],
              "series_items": [],
              "patch_summary": "This patch improves the performance of the IOCB_DONTCACHE writeback path by moving writeback submission off the writer's hot path and into a background flusher. The patch introduces a new WB_start_dontcache bit that uses targeted dirty tracking to determine how many pages to write back, preserving I/O batching while limiting the scope of expedited writeback. This results in significant improvements in throughput and tail latency for sequential writes, as well as improved performance in multi-writer scenarios.",
              "analysis_source": "llm-chunked-no-replies",
              "review_comments": [],
              "list_id": "linux-nfs@vger.kernel.org"
            }
          ],
          "patch_summary": "This patch series aims to improve write performance when using the RWF_DONTCACHE flag, which prevents caching of written data. The patches track dirty pages per block device and kick a flusher thread to write back a proportional number of pages after a DONTCACHE write. This approach is intended to reduce the overhead associated with frequent writeback operations.",
          "analysis_source": "llm-chunked-no-replies",
          "review_comments": [],
          "list_id": "linux-nfs@vger.kernel.org"
        }
